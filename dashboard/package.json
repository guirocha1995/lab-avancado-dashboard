{
  "name": "lab-avancado-dashboard",
  "version": "1.0.0",
  "description": "Retail Operations Dashboard - Lab Avançado Azure",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
