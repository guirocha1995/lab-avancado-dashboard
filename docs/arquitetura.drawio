          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- All Functions → Callback (notify events) -->
        <mxCell id="conn-func-callback1" value="&lt;font color=&quot;#28a745&quot;&gt;POST /api/events/notify&lt;br&gt;(todos os eventos)&lt;/font&gt;" style="strokeColor=#28a745;strokeWidth=2;endArrow=blockThin;endFill=1;fontSize=8;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="durable-container" target="callback-endpoint" edge="1">
